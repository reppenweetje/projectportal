# Kopieer naar .env.local en vul in. Voor Vercel: zet dezelfde keys in
# Project Settings → Environment Variables (Production + Preview + Development).

# ─── Bestaand (clean URLs in single-project mode) ────────────────────────────

# Single-project mode: maakt /units → /de-hofman/units intern. Zonder deze
# var draait de site in multi-project mode (/de-hofman/units zichtbaar).
NEXT_PUBLIC_DEFAULT_PROJECT=de-hofman

# ─── Portal session (fase 3, nieuw) ──────────────────────────────────────────

# Supabase project URL en publieke anon key. Middleware roept hiermee de
# portal-resolve Edge Function aan om `?t=PORTAL_TOKEN` of `dh_session`
# cookies in te wisselen voor session-data.
NEXT_PUBLIC_SUPABASE_URL=https://vgdwgjthvltucabqfysd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# HMAC secret voor het signen van het dh_profile cookie. NIET met
# NEXT_PUBLIC_ prefix — alleen server-side bekend. Genereer 64 hex chars:
#   openssl rand -hex 32
# Roteren = alle bestaande dh_profile cookies worden ongeldig (bezoekers
# zien even geen "Welkom terug" totdat ze opnieuw inloggen). dh_session
# cookies blijven werken want die zijn niet signed.
PORTAL_COOKIE_SECRET=
